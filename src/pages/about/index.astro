---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const members = await getCollection('about');
---

<BaseLayout title="Team | Embenauts">
  <h1>Team</h1>
  <ul class="about-list">
    {members.map(member => (
      <li>
        <a href={`/about/${member.slug}/`} class="about-card">
          {member.data.photo && (
            <div class="about-photo-wrap">
              <img
                src={member.data.photo}
                alt={member.data.name}
                class="about-photo"
                style={`--zoom: ${member.data.photoZoom ?? 1}; --offset-y: ${member.data.photoOffsetY ?? 0}%`}
              />
            </div>
          )}
          <div>
            <strong>{member.data.name}</strong>
            <p>{member.data.role}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .about-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .about-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .about-card:hover {
    border-color: var(--blue);
    text-decoration: none;
  }

  .about-photo-wrap {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: translateY(var(--offset-y, 0%)) scale(var(--zoom, 1));
    transform-origin: center center;
  }

  .about-card p {
    margin: 0.2rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
