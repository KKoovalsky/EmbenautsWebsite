---
import { getEntry, render } from 'astro:content';
import CondensedResumeLayout from '../layouts/CondensedResumeLayout.astro';

const entry = await getEntry('posts', 'resume-condensed');
if (!entry) throw new Error('resume-condensed.md not found');
const { Content } = await render(entry);
---
<CondensedResumeLayout title="Kacper Kowalski – Resume">
  <Content />
</CondensedResumeLayout>
