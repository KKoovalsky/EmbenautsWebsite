---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const members = await getCollection('team');
---

<BaseLayout title="Team | Embenauts">
  <h1>Team</h1>
  <ul class="team-list">
    {members.map(member => (
      <li class="team-card">
        {member.data.photo && (
          <div class="team-photo-wrap">
            <img
              src={member.data.photo}
              alt={member.data.name}
              class="team-photo"
              style={`--zoom: ${member.data.photoZoom ?? 1}; --offset-y: ${member.data.photoOffsetY ?? 0}%`}
            />
          </div>
        )}
        <div>
          <a href={`/team/${member.slug}/`}><strong>{member.data.name}</strong></a>
          <p>{member.data.role}</p>
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .team-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .team-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .team-photo-wrap {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .team-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: translateY(var(--offset-y, 0%)) scale(var(--zoom, 1));
    transform-origin: center center;
  }

  .team-card p {
    margin: 0.2rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
